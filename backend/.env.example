# --- Required in every environment ---

# MongoDB connection string. For Atlas use the +srv form.
MONGODB_URI=mongodb://localhost:27017/cim-amplify

# Used to sign auth JWTs AND HMAC the email-action tokens.
# MUST be at least 16 chars. The app refuses to boot in production
# (NODE_ENV=production) if this is missing or too short.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=change-me-to-a-real-secret-of-at-least-16-chars

# Where the Next.js frontend is served. Used in email links and CORS.
FRONTEND_URL=http://localhost:3000

# Where this backend is served. Used in Swagger config + email-callback URLs.
BACKEND_URL=http://localhost:5001

# Outbound SMTP credentials (e.g. Gmail app password / SES).
EMAIL_USER=no-reply@example.com
EMAIL_PASS=

# Address that receives admin notifications (deal closed, etc.).
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# Google OAuth (login-with-Google for buyer & seller).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional ---

# Production / development. Affects logging, CSP, and JWT_SECRET enforcement.
NODE_ENV=development

# HTTP listen port (defaults to 5001).
PORT=5001

# Optional outbound webhook the global exception filter posts to on errors.
# Leave blank to disable.
ERROR_MONITORING_WEBHOOK_URL=

# Used by the optional Anthropic-powered classification service.
ANTHROPIC_API_KEY=

# Set to "1" automatically by Vercel; toggles serverless-specific code paths
# (skips local Uploads dir, etc.). Don't set this manually unless you know why.
# VERCEL=1
